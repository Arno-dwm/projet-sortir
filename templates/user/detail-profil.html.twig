{% extends 'base.html.twig' %}

{% block title %}Détail Profil {% endblock %}

{% block body %}
    <div class="container-fluid mt-5 d-flex justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">

                    <a href="{{ path('app_home') }}" class="btn btn-secondary mt-2">Retour</a>

                    <h1 class="text-center">{{ user.username }}</h1>

                    <div class="row justify-content-center">
                        <div class="col-12 col-md-8">


                            <div class="row justify-content-center">

                                <img src="{{ asset('images/users/' ~user.urlPhoto) }}" alt="Photo Profil"
                                     class="img-fluid"
                                     style="max-width:300px;">
                                <div class="row justify-content-end">
                                    <div class="col-md-6 mb-3 text-end">
                                        <p>Prénom : </p>
                                        <p>Nom : </p>
                                        <p>Téléphone : </p>
                                        <p>Email : </p>
                                        <p>Ville de rattachement : </p>

                                    </div>
                                    <div class="col-md-6 mb-3 text-start">
                                        <p>{{ user.prenom |capitalize }}</p>
                                        <p>{{ user.nom |capitalize }}</p>
                                        <p>{{ user.telephone }}</p>
                                        <p>{{ user.mail }}</p>
                                        <p>{{ user.site.getNom }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion accordion-flush" id="accordionFlushExample">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="flush-headingOne">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne" aria-expanded="false" aria-controls="flush-collapseOne">
                                    Afficher les sorties à venir de cet organisateur
                                </button>
                            </h2>
                            <div id="flush-collapseOne" class="accordion-collapse collapse" aria-labelledby="flush-headingOne" data-bs-parent="#accordionFlushExample">
                                <div class="accordion-body">
                                    <table class="table table-hover border">

                                        <thead class="table-primary">
                                        <tr>
                                            <th>Nom</th>
                                            <th>Date de début</th>
                                            <th>durée</th>
                                            <th>Date limite inscription</th>
                                            <th>Places restantes</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for sortie in sorties | filter(s => 'OUV' in s.etat.code or s => 'CLO' in s.etat.code) %}
                                            <tr>
                                                <td><a href="{{ path('app_sortie_detail', {id : sortie.id}) }}">{{ sortie.nom|upper }}</a></td>
                                                <td>{{ sortie.dateHeureDebut |date('d/m/Y H:i') }} </td>
                                                <td>{{ sortie.duree }}</td>
                                                <td>{{ sortie.dateLimiteInscription |date('d/m/Y' ) }} </td>
                                                {% if sortie.dateLimiteInscription > date('now') %}
                                                <td class="table-success">{{ sortie.nbInscriptionsMax - sortie.inscriptions.count }}</td>
                                                {% else %}
                                                    <td class="table-danger"> inscriptions clôturées</td>
                                                {% endif %}
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
{% endblock %}
