{% extends 'base.html.twig' %}

{% block title %}Détail Profil {% endblock %}

{% block body %}
    <div class="mx-auto w-75 text-center mt-2">

        <div class="row justify-content-center text-center  mx-auto ">
            <h1>{{ user.username }}</h1>
            <div class="container text-start mt-2">
                <div class="row align-items-start">
                    <div class="col-3">
                        <p>Notre futur image</p>
                    </div>
                    <div class="col-4">
                        <p>Prénom : </p>
                        <p>Nom : </p>
                        <p>Téléphone : </p>
                        <p>Email : </p>
                        <p>Ville de rattachement : </p>
                        <a href="{{ path('app_home') }}" class="btn btn-primary mt-2">Retour</a>
                    </div>
                    <div class="col-5">
                        <p>{{ user.prenom |capitalize }}</p>
                        <p>{{ user.nom |capitalize }}</p>
                        <p>{{ user.telephone }}</p>
                        <p>{{ user.mail }}</p>
                        <p>{{ user.site.getNom }}</p>
                    </div>
                </div>


            </div>
        </div>

    </div>
{% endblock %}
