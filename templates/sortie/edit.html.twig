{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} - {{ sortie is defined and sortie.id is not null ? 'Editer la sortie ' ~ sortie.id : 'Création sortie' }}
{% endblock %}

{% block body %}

    <div class="container-fluid mt-5 d-flex justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">


                    {% if sortie is defined and sortie.id is not null %}
                        <h2 class="text-center mb-4">Modifier la Sortie</h2>
                    {% else %}
                        <h2 class="text-center mb-4">Créer une nouvelle Sortie</h2>
                    {% endif %}

                    <div class="row justify-content-center">
                        <div class="col-12 col-md-8">
                            {# Affichage des erreurs globales du formulaire #}
                            {% if sortieForm.vars.errors|length > 0 %}
                                <div class="alert alert-danger">
                                    {{ form_errors(sortieForm) }}
                                </div>
                            {% endif %}

                            {{ form_start(sortieForm) }}

                            <div class="row">
                                {% for field in sortieForm %}
                                    {% if field.vars.name == 'infosSortie' %}
                                        <div class="col-12 mb-3">
                                            {{ form_row(field) }}
                                        </div>
                                    {% else %}
                                        <div class="col-md-6 mb-3">
                                            {{ form_row(field) }}
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                            <div class="d-flex gap-2 mt-1">
                                <button type="submit" name="action" value="CRE" class="btn btn-secondary flex-fill">
                                    Enregistrer
                                </button>

                                <button type="submit" name="action" value="OUV" class="btn btn-primary flex-fill">
                                    Publier la sortie
                                </button>
                                {% if sortie.id is not null %}
                                    <a href="{{ path('app_sortie_detail', {id: sortie.id}) }}" class="btn btn-warning flex-fill">
                                        Annuler la saisie
                                    </a>
                                {% else %}
                                    <a href="{{ path('app_home') }}" class="btn btn-warning flex-fill">
                                        Annuler la saisie
                                    </a>
                                {% endif %}
                                {{ form_end(sortieForm, { render_rest: false }) }}

                            </div>
                            {% if sortie.id is not null %}
                                <form method="post"
                                      action="{{ path('app_sortie_suppression', {id: sortie.id}) }}"
                                      onsubmit="return confirm('Voulez-vous vraiment supprimer cette sortie ?');"
                                      class="mt-4">

                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ sortie.id) }}">

                                    <button type="submit" class="btn btn-danger w-100">
                                        Supprimer la sortie
                                    </button>
                                </form>
                            {% endif %}

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const lieux = {{ lieux|json_encode|raw }};

            const select = document.getElementById('{{ sortieForm.lieu.vars.id }}');
            const rueField = document.getElementById('{{ sortieForm.rue.vars.id }}');
            const cpField = document.getElementById('{{ sortieForm.codePostal.vars.id }}');
            const latitudeField = document.getElementById('{{ sortieForm.latitude.vars.id }}');
            const longitudeField = document.getElementById('{{ sortieForm.longitude.vars.id }}');

            if (!select) return ;

            function updateLieuFields(){

                const id = select.value;

                if (lieux[id]) {
                    if (rueField) rueField.value = lieux[id].rue ?? '';
                    if (cpField) cpField.value = lieux[id].codePostal ?? '';
                    if (latitudeField) latitudeField.value = lieux[id].latitude ?? '';
                    if (longitudeField) longitudeField.value = lieux[id].longitude ?? '';
                } else {
                    if (rueField) rueField.value = '';
                    if (cpField) cpField.value = '';
                    if (latitudeField) latitudeField.value = '';
                    if (longitudeField) longitudeField.value = '';
                }
            }

            // remplir au changement
            select.addEventListener('change', updateLieuFields);

            // remplir au chargement si une valeur est déjà sélectionnée
            updateLieuFields();


        });
    </script>

{% endblock %}




