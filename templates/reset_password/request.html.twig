{% extends 'base.html.twig' %}

{% block title %}Réinitialiser votre mot de passe{% endblock %}

{% block body %}
    <div class="container vh-100 d-flex align-items-center justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">

                    {% for flash_error in app.flashes('reset_password_error') %}
                        <div class="alert alert-danger" role="alert">
                            {{ flash_error }}
                        </div>
                    {% endfor %}

                    <h1 class="h3 mb-4 text-center fw-bold">
                        Réinitialiser votre mot de passe
                    </h1>

                    <p class="text-muted text-center mb-4">
                        Entrez votre adresse e-mail et nous vous enverrons un lien pour réinitialiser votre mot de passe.
                    </p>

                    {{ form_start(requestForm) }}

                    <div class="mb-3">
                        {{ form_label(requestForm.mail, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(requestForm.mail, {

                            'attr': {
                                'class': 'form-control form-control-lg',
                                'placeholder': 'Votre adresse e-mail',

                            }
                        }) }}
                        {{ form_errors(requestForm.mail) }}
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-primary btn-lg rounded-3">
                            Envoyer un e-mail de réinitialisation
                        </button>
                    </div>

                    {{ form_end(requestForm) }}

                    <div class="text-center mt-4">
                        <a href="{{ path('app_login') }}">
                            Retour à la connexion
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}
