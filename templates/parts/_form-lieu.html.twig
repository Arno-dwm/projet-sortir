
<turbo-frame id="modal-frame">
<h2>Ajouter un nouveau lieu</h2>
{{ form_start(formlieu, {
    action: path('app_lieu_create'),
    attr: {
        id: 'category-form',
        'data-turbo-frame': 'modal-frame'
    }
}) }}
    {{ form_row(formlieu.nom) }}
    {{ form_row(formlieu.rue) }}
    {{ form_row(formlieu.latitude) }}
    {{ form_row(formlieu.longitude) }}
    {{ form_row(formlieu.ville) }}
    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a id="btnClose" class="btn btn-secondary" data-action="close-modal">Fermer</a>
{{ form_end(formlieu) }}


</turbo-frame>
